---
interface Props {
  title?: string
}
const { title = 'Susuppy AR' } = Astro.props
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #0a0a0a;
        color: #fff;
        min-height: 100dvh;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
