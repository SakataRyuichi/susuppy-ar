---
// AR体験ページ - A-Frame（8frame）+ 8th Wall xrextras
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>AR体験 | Susuppy AR</title>

    <!-- 8th Wall 版 A-Frame（8frame） -->
    <script is:inline crossorigin="anonymous" src="/external/scripts/8frame-1.5.0.min.js"></script>

    <!-- 8th Wall XR Extras（xrweb などのコンポーネントを提供） -->
    <script is:inline crossorigin="anonymous" src="/external/xrextras/xrextras.js"></script>

    <!-- 8th Wall Landing Page（デスクトップ対応の起動トリガー） -->
    <script is:inline crossorigin="anonymous" src="/external/landing-page/landing-page.js"></script>

    <!-- 8th Wall XR Engine（平面検出 SLAM を含む） -->
    <script is:inline crossorigin="anonymous" src="/external/xr/xr.js" async="true" data-preload-chunks="slam"></script>

    <style>
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #000;
      }

      #back-btn {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 9999;
        padding: 0.5rem 1rem;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 9999px;
        font-size: 0.875rem;
        text-decoration: none;
        backdrop-filter: blur(8px);
      }

      #prompt {
        position: fixed;
        bottom: 3rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        padding: 0.75rem 1.5rem;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        border-radius: 9999px;
        font-size: 0.875rem;
        white-space: nowrap;
        backdrop-filter: blur(8px);
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <a id="back-btn" href="/">← 戻る</a>
    <p id="prompt">床や机をタップしてモデルを置く</p>

    <a-scene
      tap-place
      landing-page
      xrextras-loading
      xrextras-runtime-error
      renderer="colorManagement: true"
      xrweb="allowedDevices: any"
      vr-mode-ui="enabled: false"
    >
      <a-assets>
        <!-- GLBモデルを使う場合はここに追加 -->
        <!-- <a-asset-item id="my-model" src="/ar-content/your-model.glb"></a-asset-item> -->
      </a-assets>

      <a-camera
        position="0 8 0"
        raycaster="objects: .cantap"
        cursor="fuse: false; rayOrigin: mouse"
      ></a-camera>

      <!-- 平面検出された床（透明・タップ判定あり） -->
      <a-box
        id="ground"
        class="cantap"
        scale="1000 2 1000"
        position="0 -0.99 0"
        material="shader: shadow; transparent: true; opacity: 0.4"
      ></a-box>

      <a-light type="ambient" intensity="0.8"></a-light>
      <a-light type="directional" intensity="0.5" position="1 4 2"></a-light>
    </a-scene>

    <script is:inline>
      // XR8 起動状況をデバッグ
      window.addEventListener('xrloaded', () => {
        console.log('[XR8] xrloaded イベント発火 - エンジン準備完了')
      })
      window.addEventListener('xrerror', (e) => {
        console.error('[XR8] エラー:', e.detail)
      })

      // 床タップで3Dオブジェクトを配置するコンポーネント
      AFRAME.registerComponent('tap-place', {
        init() {
          const ground = document.getElementById('ground')
          const prompt = document.getElementById('prompt')

          ground.addEventListener('click', (event) => {
            prompt.style.display = 'none'

            const entity = document.createElement('a-entity')
            const point = event.detail.intersection.point
            entity.setAttribute('position', point)

            // GLBモデルを使う場合:
            // entity.setAttribute('gltf-model', '#my-model')
            // entity.setAttribute('scale', '1 1 1')

            // デモ: 回転するボックス
            entity.setAttribute('geometry', 'primitive: box; width: 0.3; height: 0.3; depth: 0.3')
            entity.setAttribute('material', 'color: #4CC3D9')
            entity.setAttribute('position', {
              x: point.x,
              y: point.y + 0.15,
              z: point.z,
            })
            entity.setAttribute('animation', {
              property: 'rotation',
              to: '0 360 0',
              loop: true,
              dur: 3000,
              easing: 'linear',
            })

            document.querySelector('a-scene').appendChild(entity)
          })
        },
      })
    </script>
  </body>
</html>
