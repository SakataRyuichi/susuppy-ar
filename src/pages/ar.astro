---
// AR体験ページ - MindAR + A-Frame（イメージトラッキング）
const isDev = import.meta.env.DEV
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>AR体験 | Susuppy AR</title>

    <!-- A-Frame 1.5.0 (MindAR 1.2.5 の推奨バージョン) -->
    <script is:inline src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
    <!-- animation-mixer コンポーネント（GLBアニメーション再生） -->
    <script is:inline src="https://cdn.jsdelivr.net/gh/c-frame/aframe-extras@7.5.0/dist/aframe-extras.min.js"></script>
    <!-- MindAR イメージトラッキング（A-Frame統合版） -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/mind-ar@1.2.5/dist/mindar-image-aframe.prod.js"></script>

    <!-- LERPスムージングコンポーネント（mindar-image-target に付ける） -->
    <script is:inline>
      AFRAME.registerComponent('smooth-track', {
        schema: { factor: { type: 'number', default: 0.15 } },
        init() {
          this.smoothPos = new THREE.Vector3()
          this.smoothQuat = new THREE.Quaternion()
          this.ready = false
        },
        tick() {
          const obj = this.el.object3D
          // 非表示中はスキップ
          if (!obj.visible) { this.ready = false; return }

          if (!this.ready) {
            this.smoothPos.copy(obj.position)
            this.smoothQuat.copy(obj.quaternion)
            this.ready = true
            return
          }
          // MindARが毎フレームセットした位置をLERPで追従
          this.smoothPos.lerp(obj.position, this.data.factor)
          this.smoothQuat.slerp(obj.quaternion, this.data.factor)
          obj.position.copy(this.smoothPos)
          obj.quaternion.copy(this.smoothQuat)
        }
      })
    </script>

    <style>
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      #back-btn {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 9999;
        padding: 0.5rem 1rem;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 9999px;
        font-size: 0.875rem;
        text-decoration: none;
        backdrop-filter: blur(8px);
      }

      #hint {
        position: fixed;
        bottom: 3rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        padding: 0.75rem 1.5rem;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        border-radius: 9999px;
        font-size: 0.875rem;
        white-space: nowrap;
        backdrop-filter: blur(8px);
        pointer-events: none;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <a id="back-btn" href="/">← 戻る</a>
    <p id="hint">マーカー画像にカメラを向けてください</p>

    <!--
      imageTargetSrc   : .mind ファイルのパス
      filterMinCF      : 1 Euro フィルター最小カットオフ周波数（小さい=滑らか/遅延あり、大きい=俊敏/ブレあり）
      filterBeta       : 1 Euro フィルターベータ値（大きい=速い動きに追従）
      missTolerance    : 認識を失ってから消えるまでのフレーム数（大きい=ちらつき減少）
      warmupTolerance  : 認識開始に必要なフレーム数（小さい=素早く検出）
    -->
    <a-scene
      mindar-image="imageTargetSrc: /ar-content/targets.mind;
        autoStart: true;
        uiLoading: yes; uiScanning: yes; uiError: yes;
        filterMinCF: 0.001;
        filterBeta: 0.01;
        missTolerance: 10;
        warmupTolerance: 3"
      color-space="sRGB"
      renderer="colorManagement: true, physicallyCorrectLights"
      vr-mode-ui="enabled: false"
      device-orientation-permission-ui="enabled: false"
    >
      <a-assets>
        <!-- 表示したい GLB モデル -->
        <a-asset-item id="my-model" src="/ar-content/Meshy_AI_model_Animation_Walking_withSkin.glb"></a-asset-item>
      </a-assets>

      <a-camera position="0 0 0" look-controls="enabled: false"></a-camera>

      <!-- targetIndex: 0 → targets.mind の1枚目の画像を認識したときに表示 -->
      <a-entity mindar-image-target="targetIndex: 0" smooth-track="factor: 0.15">
        <!-- GLBモデル（Meshy AIモデルはmm単位のため scale=333 で約1m相当） -->
        <a-gltf-model
          id="ar-model"
          src="#my-model"
          position="0 0 0"
          scale="999 999 999"
          rotation="0 0 0"
          animation-mixer="clip: *; loop: repeat"
        ></a-gltf-model>
      </a-entity>
    </a-scene>

    <script is:inline define:vars={{ isDev }}>
      const hint = document.getElementById('hint')

      // デバッグオーバーレイ（dev環境のみ）
      function log(msg) {
        console.log('[AR]', msg)
        if (!isDev) return
        let dbg = document.getElementById('ar-dbg')
        if (!dbg) {
          dbg = document.createElement('div')
          dbg.id = 'ar-dbg'
          dbg.style.cssText = 'position:fixed;bottom:6rem;left:1rem;right:1rem;z-index:9999;background:rgba(0,0,0,0.7);color:#0f0;font-size:11px;font-family:monospace;padding:8px;border-radius:8px;max-height:40vh;overflow-y:auto;word-break:break-all;'
          document.body.appendChild(dbg)
        }
        const line = document.createElement('div')
        line.textContent = new Date().toISOString().slice(11,19) + ' ' + msg
        dbg.prepend(line)
      }

      if (isDev) {
        log('UA: ' + navigator.userAgent.slice(0, 80))
        log('HTTPS: ' + (location.protocol === 'https:'))
        log('WebGL: ' + !!document.createElement('canvas').getContext('webgl'))
        navigator.mediaDevices?.getUserMedia({video: true})
          .then(() => log('Camera: OK'))
          .catch(e => log('Camera ERROR: ' + e.name + ' ' + e.message))
      }

      const scene = document.querySelector('a-scene')
      scene.addEventListener('arReady', () => {
        log('arReady')
        hint.textContent = 'マーカー画像にカメラを向けてください'
      })
      scene.addEventListener('arError', (e) => {
        log('arError: ' + JSON.stringify(e.detail))
        hint.textContent = 'エラーが発生しました'
      })

      // GLBモデルのロード・SkinnedMeshのフラスタムカリング無効化
      const modelEl = document.getElementById('ar-model')
      if (modelEl) {
        modelEl.addEventListener('model-loaded', (e) => {
          log('GLB loaded OK')
          e.detail.model.traverse(child => {
            if (child.isSkinnedMesh || child.isMesh) child.frustumCulled = false
          })
        })
        modelEl.addEventListener('model-error', (e) => log('GLB ERROR: ' + JSON.stringify(e.detail)))
      }

      // マーカーを見失っても HOLD_MS ミリ秒間はモデルを保持する
      const HOLD_MS = 2000
      let hideTimer = null
      const targetEl = document.querySelector('[mindar-image-target]')

      targetEl?.addEventListener('targetFound', () => {
        log('targetFound!')
        // 非表示タイマーをキャンセル
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null }
        // モデルを表示状態に戻す
        if (modelEl) modelEl.setAttribute('visible', 'true')
        hint.style.display = 'none'
      })

      targetEl?.addEventListener('targetLost', () => {
        log('targetLost – holding ' + HOLD_MS + 'ms')
        hint.style.display = 'block'
        hint.textContent = 'マーカー画像にカメラを向けてください'
        // HOLD_MS 後にモデルを非表示
        hideTimer = setTimeout(() => {
          if (modelEl) modelEl.setAttribute('visible', 'false')
          hideTimer = null
        }, HOLD_MS)
      })
    </script>
  </body>
</html>
